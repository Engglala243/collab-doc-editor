generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id          String           @id @default(cuid())
  name        String
  email       String           @unique
  password    String
  documents   Document[]       @relation("DocumentOwner")
  memberships DocumentMember[]
  versions    DocumentVersion[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("users")
}

model Document {
  id        String           @id @default(cuid())
  title     String
  content   Json             @default("{}")
  ownerId   String
  sequence  Int              @default(0)
  owner     User             @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   DocumentMember[]
  updates   DocumentUpdate[]
  versions  DocumentVersion[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([ownerId])
  @@index([updatedAt])
  @@map("documents")
}

model DocumentMember {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  role       Role
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@map("document_members")
}

model DocumentUpdate {
  id         String   @id @default(cuid())
  documentId String
  clientId   String
  sequence   Int
  serverSequence Int @default(autoincrement())
  payload    String
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, clientId, sequence])
  @@index([documentId, sequence])
  @@map("document_updates")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  name        String
  content     String
  createdAt   DateTime @default(now())
  createdBy   String

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}
